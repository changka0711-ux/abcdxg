rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow read access to everyone for all files
    match /{allPaths=**} {
      allow read;
    }
    // Allow write access only to the 'images' folder for authenticated users
    match /images/{allPaths=**} {
      allow write: if request.auth != null;
    }
  }
}
