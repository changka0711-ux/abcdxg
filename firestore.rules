rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read and write their own user document.
    match /users/{userId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
    }

    // Rules for conversations, supporting both 1-on-1 and group chats.
    match /conversations/{conversationId} {
      // Any authenticated user can interact with the AI chat.
      // For other chats, only participants can read.
      allow read: if request.auth != null &&
                   (conversationId == 'AI_CHAT' || request.auth.uid in resource.data.participants);

      // Allow creating a new conversation if the user is one of the participants.
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participants;

      // Allow updates based on conversation type and user role.
      allow update: if request.auth != null && request.auth.uid in resource.data.participants && (
                      // For 1-on-1 chats (or old chats without the isGroup flag), allow any update by a participant.
                      resource.data.get('isGroup', false) == false ||
                      // For group chats, apply role-based permissions.
                      (
                        // Any participant can update the last message.
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastMessage']) ||
                        // Only the admin can update the participants list or the group name.
                        (request.auth.uid == resource.data.groupAdmin &&
                         request.resource.data.diff(resource.data).affectedKeys().hasAny(['participants', 'groupName']))
                      )
                    );

      // Messages subcollection
      match /messages/{messageId} {
        // Allow participants to read/create messages. This rule works for both chat types.
        allow read, create: if request.auth != null &&
                             (conversationId == 'AI_CHAT' || request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants);
      }
    }
  }
}
