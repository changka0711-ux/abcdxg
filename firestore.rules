rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read and write their own user document.
    match /users/{userId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
    }

    match /conversations/{conversationId} {
      // Allow any authenticated user to read/write the AI chat document.
      // For all other conversations, only participants can read/write.
      allow read, write: if request.auth != null &&
                          (conversationId == 'AI_CHAT' || request.auth.uid in resource.data.participants);

      // Allow creating a new conversation if the user is one of the participants.
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participants;

      // Messages subcollection
      match /messages/{messageId} {
        // Allow authenticated users to read/create messages in the AI chat,
        // or if they are a participant in a regular chat.
        allow read, create: if request.auth != null &&
                             (conversationId == 'AI_CHAT' || request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants);
      }
    }
  }
}
